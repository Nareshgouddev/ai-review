# ─────────────────────────────────────────────────────────────────
# AI UI Review Agent — required environment variables
# Copy this file to .env and fill in real values before running
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Anthropic API key used by the backend to call the Claude Vision API.
# Obtain yours from https://console.anthropic.com/
# The backend WILL NOT start if this variable is absent or blank.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MariaDB root password.  Used internally by the db container.
DB_ROOT_PASSWORD=change_me_root_password

# Application-level database user and password.
# The backend connects to MariaDB with these credentials.
DB_USER=uireview_user
DB_PASS=change_me_db_password

# Origin of the React frontend.
# The backend configures CORS to allow requests only from this origin.
# Change to your production domain when deploying.
FRONTEND_ORIGIN=http://localhost:3000
